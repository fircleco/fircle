    { "src": "/screenshots/members-narrow.png", "sizes": "1080x1920", "type": "image/png", "form_factor": "narrow" },
    { "src": "/screenshots/profile-narrow.png", "sizes": "1080x1920", "type": "image/png", "form_factor": "narrow" },
    {
      "src": "/screenshots/app-home-wide.png",
