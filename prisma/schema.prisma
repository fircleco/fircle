// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url      = env("DATABASE_URL")
}

enum FamilyRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteType {
  OPEN
  EMAIL_BOUND
}

enum InviteStatus {
  PENDING
  CLAIMED
  EXPIRED
  REVOKED
}

enum PostType {
  TEXT
  PHOTO
  VIDEO
  MIXED
}

enum PostMediaType {
  IMAGE
  VIDEO
}

model Family {
  id          String         @id @default(cuid())
  name        String
  image       String?
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  members     FamilyMember[]
  invites     Invite[]
}

model FamilyMember {
  id        String     @id @default(cuid())
  familyId  String
  userId    String?
  name      String
  nickname  String?
  slug      String
  image     String?
  role      FamilyRole @default(MEMBER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  claimInvites Invite[] @relation("ClaimMemberInvites")
  posts     Post[]
  comments  Comment[]   @relation("CommentAuthor")
  postLikes PostLike[]
  commentLikes CommentLike[]
  mediaTags MediaTag[]
  postMentions PostMention[] @relation("PostMentionedMember")
  commentMentions CommentMention[] @relation("CommentMentionedMember")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([familyId, userId])
  @@unique([familyId, slug])
  @@index([userId])
}

model Invite {
  id           String       @id @default(cuid())
  code         String       @unique
  type         InviteType   @default(OPEN)
  status       InviteStatus @default(PENDING)
  familyId     String
  invitedEmail String?
  createdById  String
  expiresAt    DateTime
  claimedAt    DateTime?
  claimedById  String?
  claimMemberId String?
  revokedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  createdBy User   @relation("UserCreatedInvites", fields: [createdById], references: [id], onDelete: Cascade)
  claimedBy User?  @relation("UserClaimedInvites", fields: [claimedById], references: [id], onDelete: SetNull)
  claimMember FamilyMember? @relation("ClaimMemberInvites", fields: [claimMemberId], references: [id], onDelete: SetNull)

  @@index([familyId])
  @@index([status])
  @@index([expiresAt])
  @@index([invitedEmail])
  @@index([claimMemberId])
}

model Post {
  id             String      @id @default(cuid())
  caption        String?
  type           PostType
  authorMemberId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  authorMember   FamilyMember @relation(fields: [authorMemberId], references: [id], onDelete: Cascade)
  media          PostMedia[]
  likes          PostLike[]
  comments       Comment[]
  mentions       PostMention[]

  @@index([authorMemberId])
  @@index([createdAt])
  @@index([authorMemberId, createdAt])
}

model PostMedia {
  id         String        @id @default(cuid())
  postId     String
  type       PostMediaType
  provider   String
  bucket     String
  objectKey  String
  url        String
  mimeType   String
  sizeBytes  Int
  width      Int?
  height     Int?
  durationMs Int?
  caption    String?
  sortOrder  Int
  createdAt  DateTime      @default(now())
  post       Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaTags  MediaTag[]

  @@index([postId])
  @@index([sortOrder])
  @@index([createdAt])
  @@index([postId, sortOrder])
}

model MediaTag {
  id             String       @id @default(cuid())
  postMediaId    String
  taggedMemberId String
  xPercent       Decimal?     @db.Decimal(5, 2)
  yPercent       Decimal?     @db.Decimal(5, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  postMedia      PostMedia    @relation(fields: [postMediaId], references: [id], onDelete: Cascade)
  taggedMember   FamilyMember @relation(fields: [taggedMemberId], references: [id], onDelete: Cascade)

  @@unique([postMediaId, taggedMemberId])
  @@index([postMediaId])
  @@index([taggedMemberId])
  @@index([postMediaId, taggedMemberId])
}

model PostLike {
  id               String        @id @default(cuid())
  postId           String
  memberIdWhoLiked String
  createdAt        DateTime      @default(now())

  post             Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  memberWhoLiked   FamilyMember  @relation(fields: [memberIdWhoLiked], references: [id], onDelete: Cascade)

  @@unique([postId, memberIdWhoLiked])
  @@index([postId])
  @@index([memberIdWhoLiked])
}

model PostMention {
  id                String       @id @default(cuid())
  postId            String
  mentionedMemberId String
  start             Int
  end               Int
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  post              Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  mentionedMember   FamilyMember @relation("PostMentionedMember", fields: [mentionedMemberId], references: [id], onDelete: Cascade)

  @@unique([postId, start, end])
  @@unique([postId, mentionedMemberId, start, end])
  @@index([postId, start, id])
  @@index([mentionedMemberId, createdAt])
}

model Comment {
  id              String        @id @default(cuid())
  postId          String
  authorMemberId  String
  parentCommentId String?
  content         String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  post            Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorMember    FamilyMember  @relation("CommentAuthor", fields: [authorMemberId], references: [id], onDelete: Cascade)
  parentComment   Comment?      @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[]     @relation("CommentReplies")
  likes           CommentLike[]
  mentions        CommentMention[]

  @@index([postId])
  @@index([authorMemberId])
  @@index([parentCommentId])
  @@index([postId, parentCommentId, createdAt, id])
  @@index([parentCommentId, createdAt, id])
  @@index([postId, createdAt, id])
}

model CommentLike {
  id               String        @id @default(cuid())
  commentId        String
  memberIdWhoLiked String
  createdAt        DateTime      @default(now())

  comment          Comment       @relation(fields: [commentId], references: [id], onDelete: Cascade)
  memberWhoLiked   FamilyMember  @relation(fields: [memberIdWhoLiked], references: [id], onDelete: Cascade)

  @@unique([commentId, memberIdWhoLiked])
  @@index([commentId])
  @@index([memberIdWhoLiked])
}

model CommentMention {
  id                String       @id @default(cuid())
  commentId         String
  mentionedMemberId String
  start             Int
  end               Int
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  comment           Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedMember   FamilyMember @relation("CommentMentionedMember", fields: [mentionedMemberId], references: [id], onDelete: Cascade)

  @@unique([commentId, start, end])
  @@unique([commentId, mentionedMemberId, start, end])
  @@index([commentId, start, id])
  @@index([mentionedMemberId, createdAt])
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String         @id @default(cuid())
  email          String?        @unique
  emailVerified  DateTime?
  password       String?
  accounts       Account[]
  sessions       Session[]
  memberships    FamilyMember[]
  createdInvites Invite[]       @relation("UserCreatedInvites")
  claimedInvites Invite[]       @relation("UserClaimedInvites")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
